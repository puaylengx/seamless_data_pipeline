# ============================================================
# .env.example — Seamless Data Pipeline
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริงก่อนรัน
# cp .env.example .env
# ============================================================

# ── Airflow Container ────────────────────────────────────────
# Linux: รัน `id -u` เพื่อดูค่า UID
# Windows / macOS: ใช้ 50000 ได้เลย
AIRFLOW_UID=50000

# (Optional) เปลี่ยน Airflow image version หรือ custom image
# AIRFLOW_IMAGE_NAME=apache/airflow:3.1.8

# (Optional) path โปรเจกต์ ถ้าไม่กำหนดจะใช้ directory ปัจจุบัน
# AIRFLOW_PROJ_DIR=.

# ── Airflow Web UI Admin Account ─────────────────────────────
# เปลี่ยน password ก่อนนำขึ้น production
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# ── JWT Auth (API Security) ──────────────────────────────────
# เปลี่ยนเป็น random string ที่ปลอดภัยสำหรับ production
AIRFLOW__API_AUTH__JWT_SECRET=change_me_to_a_random_secret
AIRFLOW__API_AUTH__JWT_ISSUER=airflow

# ── SMTP — Email Notification ────────────────────────────────
# Gmail: เปิด 2-Step Verification แล้วสร้าง App Password (16 หลัก)
# Google Account → Security → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_STARTTLS=false
SMTP_SSL=true
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_MAIL_FROM=Airflow Notification

# ผู้รับ email แจ้งเตือน (คั่นหลายที่อยู่ด้วย comma)
ALERT_EMAILS=recipient@example.com

# ── Finance Invoice Pipeline ─────────────────────────────────
FIN_INV_TARGET_SCHEMA=dbo
FIN_INV_TARGET_TABLE=finance_invoice_20251110
FIN_INV_KEY_COL=invoiceId
FIN_INV_BATCH_SIZE=1000

# ── Staging Student Pipeline ─────────────────────────────────
STAGING_STD_TARGET_SCHEMA=dbo
STAGING_STD_TARGET_TABLE=StagingStudent_20251105
STAGING_STD_KEY_COL=studentcode
STAGING_STD_BATCH_SIZE=1000
