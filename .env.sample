# BigQuery
BQ_PROJECT=your-gcp-project
BQ_DATASET=Education
BQ_TABLE=student_info
BQ_RAW_TABLE=student_info_raw
BQ_LOCATION=asia-southeast1

# Source DB (SQL Server)
SKY_HOST=your-sqlserver-host
SKY_DATABASE=your-database
SKY_USERNAME=your-username
SKY_PASSWORD=your-password   # ใน prod ใช้ Secret Manager แทน

# Pipeline options
MIN_ACADEMIC_YEAR=2016
SKY_STATUSES=dm,ex,g,la,np,prc,pa,rs,s

# Optional: ที่เก็บไฟล์ audit ใน GCS
AUDIT_GCS_BUCKET=your-audit-bucket
